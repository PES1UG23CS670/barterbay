public void updateUserStatus(String id, String status) {
    User user = repository.findById(id).orElseThrow();
    user.setStatus(status);
    repository.save(user);
}
public User getUserById(String id) {
    return repository.findById(id)
        .orElseThrow(() -> new RuntimeException("User not found"));
}
public UserDetailsDTO getUserDetails(String id) {

    User user = repository.findById(id)
        .orElseThrow(() -> new RuntimeException("User not found"));

    List<Report> reports = reportRepository.findByReportedUser(id);
    List<ExchangeRequest> exchanges =
        exchangeRepository.findByRequesterIdOrReceiverId(id, id);

    int reportsCount = reports.size();

    int credibility =
        (user.getTotalTrades() * 2)
      + ((int) user.getRating() * 2)
      - (reportsCount * 3);

    boolean suspicious = credibility < 0 || reportsCount > 3;

    return new UserDetailsDTO(
        user.getUsername(),
        user.getRole(),
        user.getStatus(),
        credibility,
        user.getRating(),
        user.getTotalTrades(),
        reportsCount,
        suspicious,
        reports,
        exchanges
    );
