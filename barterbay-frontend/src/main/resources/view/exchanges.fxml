<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.barterbay.frontend.controller.ExchangesController"
            stylesheets="@post-login.css"
            prefWidth="1100" prefHeight="700">

    <!-- TOP HEADER -->
    <top>
        <VBox spacing="6" styleClass="dashboard-header" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16" />
            </padding>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button fx:id="backBtn" text="← Back to Products" styleClass="back-button" 
                        style="-fx-padding: 8 16; -fx-font-size: 12;" />
                <VBox spacing="6">
                    <Label text="Pending Exchange Requests" styleClass="dashboard-title" />
                    <Label text="Review exchange requests from other users" styleClass="muted-label" />
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="logoutBtn" text="Logout" onAction="#logout"
                        style="-fx-padding: 8 20; -fx-font-size: 12; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f9fafb;">
            <VBox fx:id="exchangesContainer"
                  spacing="15"
                  style="-fx-padding: 20;" />
        </ScrollPane>
    </center>

</BorderPane>
