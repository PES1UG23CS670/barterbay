<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<!--
  ─────────────────────────────────────────────────────────────────────────────
  CHANGE vs original post-login.fxml:
    Center content: FlowPane (flat product list)
                 → ScrollPane > VBox (fx:id="productContainer")

  Why: BrowseProductsController now builds one VBox section per category
  and appends them to productContainer.  A VBox stacks sections vertically;
  the inner FlowPanes (built in Java) wrap cards horizontally as before.

  Everything else (sidebar tabs, logout button, styleClass names, fx:id values,
  onMouseClicked/onAction handlers) is UNCHANGED so existing controller
  bindings keep working.

  WHERE THIS FILE GOES:
    barterbay-frontend/src/main/resources/view/post-login.fxml
    (replaces the existing file)
  ─────────────────────────────────────────────────────────────────────────────
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.barterbay.frontend.controller.BrowseProductsController"
            stylesheets="@post-login.css">

    <!-- TOP BAR WITH LOGOUT (unchanged) -->
    <top>
        <HBox alignment="CENTER_RIGHT"
              style="-fx-padding: 15; -fx-background-color: white;
                     -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
            <Button fx:id="logoutBtn"
                    text="Logout"
                    onAction="#logout"
                    style="-fx-padding: 8 20; -fx-font-size: 12; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- SIDEBAR (unchanged) -->
    <left>
        <VBox spacing="15"
              prefWidth="220" minWidth="220" maxWidth="220"
              styleClass="sidebar">

            <Label text="BarterBay" styleClass="sidebar-title"/>

            <VBox spacing="8" fillWidth="true">

                <Label text="Browse Products"
                       fx:id="browseTab"
                       onMouseClicked="#goToBrowse"
                       maxWidth="Infinity"
                       styleClass="sidebar-tab active-tab"/>

                <Label text="My Listings"
                       fx:id="listingsTab"
                       onMouseClicked="#goToListings"
                       maxWidth="Infinity"
                       styleClass="sidebar-tab"/>

                <Label text="Exchanges"
                       fx:id="exchangesTab"
                       onMouseClicked="#goToExchanges"
                       maxWidth="Infinity"
                       styleClass="sidebar-tab"/>

            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

        </VBox>
    </left>

    <!-- MAIN CONTENT
         CHANGED: FlowPane → ScrollPane > VBox
         BrowseProductsController appends one category VBox section at a time.
    -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f9fafb;">
            <VBox fx:id="productContainer"
                  spacing="20"
                  style="-fx-padding: 10;" />
        </ScrollPane>
    </center>

</BorderPane>
