<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<!--
  ─────────────────────────────────────────────────────────────────────────────
  CHANGE vs original post-login.fxml:
    Center content: FlowPane (flat product list)
                 → ScrollPane > VBox (fx:id="productContainer")

  Why: BrowseProductsController now builds one VBox section per category
  and appends them to productContainer.  A VBox stacks sections vertically;
  the inner FlowPanes (built in Java) wrap cards horizontally as before.

  Everything else (sidebar tabs, logout button, styleClass names, fx:id values,
  onMouseClicked/onAction handlers) is UNCHANGED so existing controller
  bindings keep working.

  WHERE THIS FILE GOES:
    barterbay-frontend/src/main/resources/view/post-login.fxml
    (replaces the existing file)
  ─────────────────────────────────────────────────────────────────────────────
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.barterbay.frontend.controller.BrowseProductsController"
            stylesheets="@post-login.css">

    <!-- TOP BAR WITH LOGOUT (unchanged) -->
    <top>
        <HBox alignment="CENTER_RIGHT"
              style="-fx-padding: 15; -fx-background-color: white;
                     -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
            <Button fx:id="logoutBtn"
                    text="Logout"
                    onAction="#logout"
                    style="-fx-padding: 8 20; -fx-font-size: 12; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- SIDEBAR (unchanged) -->
    <left>
        <VBox spacing="15"
              prefWidth="220" minWidth="220" maxWidth="220"
              styleClass="sidebar">

            <Label text="BarterBay" styleClass="sidebar-title"/>

            <VBox spacing="8" fillWidth="true">

                <Label text="Browse Products"
                       fx:id="browseTab"
                       onMouseClicked="#goToBrowse"
                       maxWidth="Infinity"
                       styleClass="sidebar-tab active-tab"/>

                <Label text="My Listings"
                       fx:id="listingsTab"
                       onMouseClicked="#goToListings"
                       maxWidth="Infinity"
                       styleClass="sidebar-tab"/>

                <Label text="Exchanges"
                       fx:id="exchangesTab"
                       onMouseClicked="#goToExchanges"
                       maxWidth="Infinity"
                       styleClass="sidebar-tab"/>

            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

        </VBox>
    </left>

    <!-- MAIN CONTENT
         CHANGED: Added filter panel + active filter display + productContainer in ScrollPane
         BrowseProductsController appends one category VBox section at a time.
    -->
    <center>
        <VBox spacing="0">
            <!-- FILTER PANEL -->
            <VBox spacing="12" style="-fx-padding: 15 20; -fx-background-color: white;
                                       -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
                <Label text="🔍 Filter Products" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #111827;"/>
                
                <!-- Category Filter -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Category:" style="-fx-min-width: 80;"/>
                    <ComboBox fx:id="categoryFilterCombo" 
                              promptText="All Categories" 
                              prefWidth="180"
                              style="-fx-padding: 6 10;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                
                <!-- Price Range Filter -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Price (₹):" style="-fx-min-width: 80;"/>
                    <TextField fx:id="minPriceField" 
                               promptText="Min" 
                               prefWidth="100"
                               style="-fx-padding: 6 10;"/>
                    <Label text="to" style="-fx-padding: 0 5;"/>
                    <TextField fx:id="maxPriceField" 
                               promptText="Max" 
                               prefWidth="100"
                               style="-fx-padding: 6 10;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                
                <!-- Action Buttons -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="applyFiltersBtn"
                            text="Apply Filters"
                            onAction="#applyFilters"
                            style="-fx-padding: 8 16; -fx-font-size: 11; -fx-cursor: hand;
                                   -fx-background-color: #3b82f6; -fx-text-fill: white;"/>
                    <Button fx:id="clearFiltersBtn"
                            text="Clear Filters"
                            onAction="#clearAllFilters"
                            style="-fx-padding: 8 16; -fx-font-size: 11; -fx-cursor: hand;
                                   -fx-background-color: #ef4444; -fx-text-fill: white;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
            
            <!-- ACTIVE FILTER DISPLAY -->
            <VBox fx:id="activeFilterDisplay"
                  spacing="8"
                  style="-fx-padding: 10 20; -fx-background-color: #eff6ff;
                         -fx-border-color: #bfdbfe; -fx-border-width: 0 0 1 0;"
                  managed="false"
                  visible="false">
                <Label text="Active Filters:" style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #1e40af;"/>
                <HBox fx:id="filterBadgesContainer" spacing="8"/>
            </VBox>
            
            <!-- PRODUCT CONTAINER -->
            <ScrollPane fitToWidth="true" 
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #f9fafb;">
                <VBox fx:id="productContainer"
                      spacing="20"
                      style="-fx-padding: 10;" />
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
