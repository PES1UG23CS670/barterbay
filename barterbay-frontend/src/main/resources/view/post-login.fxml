<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.barterbay.frontend.controller.BrowseProductsController"
            stylesheets="@post-login.css">

    <!-- TOP BAR WITH LOGOUT -->
    <top>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 15; -fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
            <Button fx:id="logoutBtn" 
                    text="Logout"
                    onAction="#logout"
                    style="-fx-padding: 8 20; -fx-font-size: 12; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="15"
            prefWidth="220"
            minWidth="220"
            maxWidth="220"
            styleClass="sidebar">

            <Label text="BarterBay" styleClass="sidebar-title"/>

            <!-- NAVIGATION TABS -->
            <VBox spacing="8" fillWidth="true">

                <Label text="Browse Products"
                       fx:id="browseTab"
                       onMouseClicked="#goToBrowse"
                       maxWidth="Infinity"
                       styleClass="sidebar-tab active-tab"/>

                <Label text="My Listings"
                       fx:id="listingsTab"
                       onMouseClicked="#goToListings"
                       maxWidth="Infinity"
                       styleClass="sidebar-tab"/>

                <Label text="Exchanges"
                       fx:id="exchangesTab"
                       onMouseClicked="#goToExchanges"
                       maxWidth="Infinity"
                       styleClass="sidebar-tab"/>

            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f9fafb;">
            <FlowPane fx:id="productContainer"
                      hgap="20"
                      vgap="20"
                      prefWrapLength="900"
                      style="-fx-padding: 20;" />
        </ScrollPane>
    </center>

</BorderPane>